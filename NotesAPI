A notes management API with user registration and login using ASP.NET Core Identity and JWT tokens. Each user can only access their own notes. Built to understand authentication flow and secure endpoints.

Sample auth logic*/

[HttpPost("login")]
public async Task<IActionResult> Login([FromBody] LoginDto dto)
{
    var user = await _userManager.FindByEmailAsync(dto.Email);
    if (user == null || !await _userManager.CheckPasswordAsync(user, dto.Password))
        return Unauthorized("Invalid credentials");

    var token = _tokenService.GenerateToken(user);
    return Ok(new { token });
}
